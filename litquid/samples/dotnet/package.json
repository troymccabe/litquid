{
  "name": "litquid-sample-dotnet",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:js": "node scripts/build-js.mjs",
    "build:css": "esbuild wwwroot/css/styles.css --minify --outdir=wwwroot/dist/css",
    "build": "npm run build:js && npm run build:css",
    "watch:js": "node scripts/watch-js.mjs",
    "watch:css": "esbuild wwwroot/css/styles.css --outdir=wwwroot/dist/css --watch",
    "watch:rust": "cd ../../toolchain && cargo run --bin litquid-watch -- --input ../samples/components/templates --output ../samples/components/scripts/templates",
    "dev": "npm-run-all --parallel watch:js watch:css watch:rust"
  },
  "dependencies": {
    "@litquid/runtime": "file:../../runtime",
    "lit": "^3.1.0"
  },
  "devDependencies": {
    "chokidar": "^3.6.0",
    "esbuild": "^0.20.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.0"
  }
}
