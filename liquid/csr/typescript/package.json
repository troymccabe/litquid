{
  "name": "@litquid/liquid-clienttemplatevalue",
  "version": "1.0.0",
  "description": "LitQuid Liquid filter for marking client-side template values",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
