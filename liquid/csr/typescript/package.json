  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "liquidjs": "^10.0.0"
  },
  "devDependencies": {
    "liquidjs": "^10.10.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "liquid",
    "liquidjs",
    "filter",
    "litquid",
    "ssr"
  ],
  "license": "MIT"
}
